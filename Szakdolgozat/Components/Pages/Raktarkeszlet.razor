@page "/raktarkeszlet"
@using Szakdolgozat.Models
@using System.Globalization
@inject Services.StockService StockService
@inject Services.ProductService ProductService
@inject Services.WarehouseService WarehouseService

<h2>Raktárkészlet lista</h2>

<div class="p-toolbar" style="gap:10px; flex-wrap:wrap;">
    <input class="p-search"
           placeholder="Keresés (raktár kód, cikkszám)..."
           value="@_search"
           @oninput="OnSearchInput" />

    <div style="display:flex; align-items:center; gap:8px;">
        <span style="white-space:nowrap;">Raktár</span>
        <select class="p-search" style="min-width:260px;" value="@_selectedWarehouseId" @onchange="OnWarehouseChanged" disabled="@_loading">
            <option value="0">Összes</option>
            @foreach (var w in _warehousesFiltered)
            {
                <option value="@w.Id">@w.Name (@w.Code)</option>
            }
        </select>
    </div>

    <label style="display:flex; align-items:center; gap:8px; white-space:nowrap;">
        <input type="checkbox" checked="@_automataOnly" @onchange="OnAutomataChanged" disabled="@_loading" />
        Automata
    </label>

    <div style="display:flex; align-items:center; gap:8px;">
        <span style="white-space:nowrap;">Időpont</span>
        <input type="date" value="@_asOfDateStr" @onchange="OnAsOfDateChanged" disabled="@_loading" />
        <button class="p-btn secondary" type="button" @onclick="ClearAsOf" disabled="@_loading || string.IsNullOrWhiteSpace(_asOfDateStr)">Törlés</button>
    </div>

    <button class="p-btn secondary" type="button" @onclick="Reload" disabled="@_loading">Frissítés</button>
</div>

@if (_loading)
{
    <p>Betöltés...</p>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <p class="p-error">@_error</p>
}
else if (_rows.Count == 0)
{
    <p>Nincs adat.</p>
}
else
{
    <div class="p-table-wrap">
        <table class="p-table">
            <thead>
                <tr>
                    <th style="width:160px;">Raktár kód</th>
                    <th style="width:260px;">Raktár név</th>
                    <th style="width:160px;">Cikkszám</th>
                    <th>Termék név</th>
                    <th style="width:140px;">Mennyiség</th>
                    <th style="width:180px;">@(_asOfActive ? "Időpont" : "Frissítve")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _rows)
                {
                    <tr>
                        <td>@r.WarehouseCode</td>
                        <td title="@r.WarehouseName">@r.WarehouseName</td>
                        <td>@r.ProductCode</td>
                        <td title="@r.ProductName">@r.ProductName</td>
                        <td>@r.Qty.ToString("0.####")</td>
                        <td>@(_asOfActive? _asOfDisplay : r.UpdatedAt.ToString("yyyy-MM-dd HH:mm"))</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool _loading = true;
    private string _error = "";
    private string _search = "";
    private CancellationTokenSource? _cts;

    private List<Row> _rowsAll = new();
    private List<Row> _rows = new();

    private List<Warehouse> _warehouses = new();
    private List<Warehouse> _warehousesFiltered = new();
    private Dictionary<int, string> _whCodeById = new();
    private Dictionary<string, Warehouse> _whByCode = new(StringComparer.OrdinalIgnoreCase);

    private int _selectedWarehouseId = 0;
    private bool _automataOnly;

    private string _asOfDateStr = "";
    private bool _asOfActive;
    private string _asOfDisplay = "";

    private sealed class Row
    {
        public string WarehouseCode { get; set; } = "";
        public string WarehouseName { get; set; } = "";
        public string ProductCode { get; set; } = "";
        public string ProductName { get; set; } = "";
        public decimal Qty { get; set; }
        public DateTime UpdatedAt { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";

        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        try
        {
            await Task.Delay(250, token);
            await LoadAsync();
        }
        catch (TaskCanceledException) { }
    }

    private void OnWarehouseChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
            _selectedWarehouseId = id;
        else
            _selectedWarehouseId = 0;

        ApplyFilters();
        StateHasChanged();
    }

    private void OnAutomataChanged(ChangeEventArgs e)
    {
        _automataOnly = e.Value is bool b && b;
        RefreshWarehouseFilterList();

        if (_selectedWarehouseId != 0 && !_warehousesFiltered.Any(x => x.Id == _selectedWarehouseId))
            _selectedWarehouseId = 0;

        ApplyFilters();
        StateHasChanged();
    }

    private async Task OnAsOfDateChanged(ChangeEventArgs e)
    {
        _asOfDateStr = e.Value?.ToString() ?? "";
        await LoadAsync();
    }

    private async Task ClearAsOf()
    {
        _asOfDateStr = "";
        await LoadAsync();
    }

    private Task Reload() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = "";
        StateHasChanged();

        try
        {
            var products = await ProductService.GetAllAsync(search: null, take: 5000);
            _warehouses = await WarehouseService.GetAllAsync(search: null, take: 5000);

            _whCodeById = _warehouses
                .Where(x => !string.IsNullOrWhiteSpace(x.Code))
                .ToDictionary(x => x.Id, x => x.Code.Trim());

            _whByCode = _warehouses
                .Where(x => !string.IsNullOrWhiteSpace(x.Code))
                .GroupBy(x => x.Code.Trim(), StringComparer.OrdinalIgnoreCase)
                .ToDictionary(g => g.Key, g => g.First(), StringComparer.OrdinalIgnoreCase);

            RefreshWarehouseFilterList();

            List<StockItem> stock;

            _asOfActive = TryParseDate(_asOfDateStr, out var d);
            if (_asOfActive)
            {
                var asOfEnd = d.Date.AddDays(1).AddTicks(-1);
                _asOfDisplay = d.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
                stock = await StockService.GetAsOfAsync(asOfEnd, _search, take: 5000);
            }
            else
            {
                _asOfDisplay = "";
                stock = await StockService.GetAllAsync(_search, take: 5000);
            }

            var prodByCode = products
                .Where(x => !string.IsNullOrWhiteSpace(x.Code))
                .GroupBy(x => x.Code.Trim(), StringComparer.OrdinalIgnoreCase)
                .ToDictionary(g => g.Key, g => g.First().Name ?? "", StringComparer.OrdinalIgnoreCase);

            _rowsAll = stock.Select(s =>
            {
                var whCode = (s.WarehouseCode ?? "").Trim();
                var whName = _whByCode.TryGetValue(whCode, out var wh)
                    ? $"{wh.Name} ({wh.Code})"
                    : "";

                var prodCode = (s.ProductCode ?? "").Trim();
                var prodName = prodByCode.TryGetValue(prodCode, out var pn) ? pn : "";

                return new Row
                {
                    WarehouseCode = whCode,
                    WarehouseName = whName,
                    ProductCode = prodCode,
                    ProductName = prodName,
                    Qty = s.Qty,
                    UpdatedAt = s.UpdatedAt
                };
            }).ToList();

            ApplyFilters();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _rowsAll = new();
            _rows = new();
            _warehouses = new();
            _warehousesFiltered = new();
            _whCodeById = new();
            _whByCode = new(StringComparer.OrdinalIgnoreCase);
            _asOfActive = false;
            _asOfDisplay = "";
        }

        _loading = false;
        StateHasChanged();
    }

    private void RefreshWarehouseFilterList()
    {
        _warehousesFiltered = _automataOnly
            ? _warehouses.Where(w => w.IsAutomaton).OrderBy(w => w.Name).ThenBy(w => w.Code).ToList()
            : _warehouses.OrderBy(w => w.Name).ThenBy(w => w.Code).ToList();
    }

    private void ApplyFilters()
    {
        IEnumerable<Row> q = _rowsAll;

        q = q.Where(r => Math.Round(r.Qty, 4) != 0m);

        if (_automataOnly)
        {
            var allowed = new HashSet<string>(
                _warehouses.Where(w => w.IsAutomaton && !string.IsNullOrWhiteSpace(w.Code)).Select(w => w.Code.Trim()),
                StringComparer.OrdinalIgnoreCase);

            q = q.Where(r => allowed.Contains((r.WarehouseCode ?? "").Trim()));
        }

        if (_selectedWarehouseId != 0 && _whCodeById.TryGetValue(_selectedWarehouseId, out var code))
        {
            var c = (code ?? "").Trim();
            q = q.Where(r => string.Equals((r.WarehouseCode ?? "").Trim(), c, StringComparison.OrdinalIgnoreCase));
        }

        _rows = q
            .OrderBy(r => r.WarehouseCode)
            .ThenBy(r => r.ProductCode)
            .ToList();
    }

    private static bool TryParseDate(string? s, out DateTime d)
    {
        d = default;
        if (string.IsNullOrWhiteSpace(s)) return false;

        if (DateTime.TryParseExact(s.Trim(), "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out d))
            return true;

        return DateTime.TryParse(s, CultureInfo.InvariantCulture, DateTimeStyles.None, out d);
    }
}